generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String?
  provider    String    // kakao | google
  providerId  String    @map("provider_id")
  plan        String    @default("free") // free | pro
  planExpires DateTime? @map("plan_expires") @db.Timestamptz
  activePetId    String?   @map("active_pet_id") @db.Uuid
  onboardingDone Boolean   @default(false) @map("onboarding_done")
  nickname       String?
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  pets              Pet[]
  letters           Letter[]
  gardenMessages    GardenMessage[]
  gardenStickers    GardenSticker[]
  gardenComments    GardenComment[]
  pushSubscriptions PushSubscription[]
  payments          Payment[]

  @@unique([provider, providerId])
  @@map("users")
}

model Pet {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  species         String   // dog | cat | hamster | parrot | other
  breed           String?
  bornAt          DateTime @map("born_at") @db.Date
  diedAt          DateTime @map("died_at") @db.Date
  personalityTags String[] @map("personality_tags")
  favoriteThings  String[] @map("favorite_things")
  farewellType    String?  @map("farewell_type") // natural | euthanasia | accident | other
  ownerNickname   String?  @map("owner_nickname")
  firstWord       String?  @map("first_word")
  profileImageUrl String?  @map("profile_image_url")
  togetherDays    Int      @default(0) @map("together_days")
  gardenPublic    Boolean  @default(true) @map("garden_public")
  commentAllowed  Boolean  @default(true) @map("comment_allowed")
  memoryProfile   Json?    @map("memory_profile")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user            User             @relation(fields: [userId], references: [id])
  letters         Letter[]
  emotionLogs     EmotionLog[]
  journeyProgress JourneyProgress?
  photoCards      PhotoCard[]
  gardenStickers  GardenSticker[]
  gardenComments  GardenComment[]

  @@map("pets")
}

// 49일 여정 질문 (7주 × 7일)
model Question {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  week       Int     // 1~7 주차
  day        Int     // 1~7 (7=쉼표)
  orderIndex Int     @map("order_index") // 전체 정렬 1~49
  category   String? // 소제목
  content    String  // 질문 본문
  isRest     Boolean @default(false) @map("is_rest")   // true = 7일차 쉼표
  restGuide  String? @map("rest_guide")                // 쉼표 날 안내 문구
  hintText   String? @map("hint_text")                 // 선택적 힌트
  // 하위 호환 필드
  stage      Int     @default(1)                       // week 와 동일값으로 유지
  isComma    Boolean @default(false) @map("is_comma")  // isRest alias
  isSmile    Boolean @default(false) @map("is_smile")

  letters Letter[]

  @@map("questions")
}

// 주차별 안내문 (7개)
model WeekGuide {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  week     Int    @unique // 1~7
  keyword  String         // 머무름, 쏟아냄 ...
  title    String
  subtitle String
  guide    String

  @@map("week_guides")
}

model Letter {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  petId      String   @map("pet_id") @db.Uuid
  questionId String?  @map("question_id") @db.Uuid
  emotionTag String?  @map("emotion_tag")
  content    String
  keywords     String[] @default([])
  imageUrls    String[] @map("image_urls")
  stage        Int
  week         Int
  day          Int
  letterStatus String   @default("normal") @map("letter_status") // normal | crisis_held
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User      @relation(fields: [userId], references: [id])
  pet      Pet       @relation(fields: [petId], references: [id])
  question Question? @relation(fields: [questionId], references: [id])
  reply    Reply?

  @@map("letters")
}

model Reply {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  letterId    String    @unique @map("letter_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  petId       String    @map("pet_id") @db.Uuid
  content     String
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at") @db.Timestamptz
  generatedAt DateTime  @default(now()) @map("generated_at") @db.Timestamptz
  // 보관함 노출/알림 예약 시각 (null = 즉시 노출, 레거시 호환)
  visibleAt   DateTime? @map("visible_at") @db.Timestamptz
  // 푸시 발송 완료 시각 (null = 미발송)
  notifiedAt  DateTime? @map("notified_at") @db.Timestamptz

  letter   Letter        @relation(fields: [letterId], references: [id])
  feedback ReplyFeedback?

  @@map("replies")
}

model ReplyFeedback {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  replyId      String   @unique @map("reply_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  petId        String   @map("pet_id") @db.Uuid
  rating       String   // positive | negative
  week         Int
  stage        Int
  letterType   String   @map("letter_type")   // normal | comma_auto | long
  farewellType String?  @map("farewell_type")
  emotionTag   String?  @map("emotion_tag")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  reply Reply @relation(fields: [replyId], references: [id])

  @@map("reply_feedbacks")
}

// 답장 안전 이벤트 로그 (crisis 감지 / fallback 대체 / 검증 실패) — 관리자 사후 추적용
model ReplySafetyEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  letterId  String?  @map("letter_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  petId     String   @map("pet_id") @db.Uuid
  eventType String   @map("event_type") // crisis_detected | fallback_used | validation_failed
  detail    String   // 매칭 사유 / 검증 레벨 / fallback 종류 등
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([eventType, createdAt])
  @@map("reply_safety_events")
}

model EmotionLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  petId      String   @map("pet_id") @db.Uuid
  emotionTag String   @map("emotion_tag")
  letterId   String?  @map("letter_id") @db.Uuid
  loggedAt   DateTime @default(now()) @map("logged_at") @db.Date

  pet Pet @relation(fields: [petId], references: [id])

  @@map("emotion_logs")
}

model JourneyProgress {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  petId              String    @unique @map("pet_id") @db.Uuid
  currentStage       Int       @default(1) @map("current_stage")
  currentWeek        Int       @default(1) @map("current_week")
  // 이번 주 완료한 문항 수 (0~7, 쉼표 포함)
  currentDay         Int       @default(0) @map("current_day")
  weekUnlocked       Boolean   @default(false) @map("week_unlocked")
  totalLetters       Int       @default(0) @map("total_letters")
  totalMinutes       Int       @default(0) @map("total_minutes")
  completedAt        DateTime? @map("completed_at") @db.Timestamptz // 7주차 완료
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  pet Pet @relation(fields: [petId], references: [id])

  @@map("journey_progress")
}

model PhotoCard {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  petId     String   @map("pet_id") @db.Uuid
  stage     Int
  imageUrl  String   @map("image_url")
  quote     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  pet Pet @relation(fields: [petId], references: [id])

  @@map("photo_cards")
}

model GardenSticker {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromUserId  String   @map("from_user_id") @db.Uuid
  toPetId     String   @map("to_pet_id") @db.Uuid
  stickerType String   @map("sticker_type") // candle | flower | heart
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  fromUser User @relation(fields: [fromUserId], references: [id])
  toPet    Pet  @relation(fields: [toPetId], references: [id])

  @@unique([fromUserId, toPetId, stickerType])
  @@map("garden_stickers")
}

model GardenMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String
  isHidden  Boolean  @default(false) @map("is_hidden")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("garden_messages")
}

model GardenComment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  toPetId   String   @map("to_pet_id") @db.Uuid
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user  User @relation(fields: [userId], references: [id])
  toPet Pet  @relation(fields: [toPetId], references: [id])

  @@map("garden_comments")
}

model PushSubscription {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  endpoint    String   @unique
  p256dh      String
  auth        String
  notifHour   Int      @default(9)    @map("notif_hour")
  notifMinute Int      @default(0)    @map("notif_minute")
  notifAmpm   String   @default("오전") @map("notif_ampm")
  notifDays   String   @default("1111111") @map("notif_days") // Mon~Sun, '1'=on
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt       @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("push_subscriptions")
}

model Payment {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  orderId String   @unique @map("order_id")
  amount  Int
  plan    String   // pro
  status  String   // success | fail
  paidAt  DateTime @default(now()) @map("paid_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("payments")
}
