generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String?
  provider    String    // kakao | google
  providerId  String    @map("provider_id")
  plan        String    @default("free") // free | pro
  planExpires DateTime? @map("plan_expires") @db.Timestamptz
  activePetId String?   @map("active_pet_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  pets              Pet[]
  letters           Letter[]
  gardenMessages    GardenMessage[]
  gardenStickers    GardenSticker[]
  pushSubscriptions PushSubscription[]
  payments          Payment[]

  @@unique([provider, providerId])
  @@map("users")
}

model Pet {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  species         String   // dog | cat | hamster | parrot | other
  breed           String?
  bornAt          DateTime @map("born_at") @db.Date
  diedAt          DateTime @map("died_at") @db.Date
  personalityTags String[] @map("personality_tags")
  favoriteThings  String[] @map("favorite_things")
  farewellType    String?  @map("farewell_type") // natural | euthanasia | accident | other
  ownerNickname   String?  @map("owner_nickname")
  lastMessage     String?  @map("last_message")
  profileImageUrl String?  @map("profile_image_url")
  gardenPublic    Boolean  @default(true) @map("garden_public")
  commentAllowed  Boolean  @default(true) @map("comment_allowed")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user            User             @relation(fields: [userId], references: [id])
  letters         Letter[]
  emotionLogs     EmotionLog[]
  journeyProgress JourneyProgress?
  photoCards      PhotoCard[]
  gardenStickers  GardenSticker[]

  @@map("pets")
}

model Question {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stage    Int     // 1~5
  week     Int     // 1~7
  day      Int     // 1~6 (7은 쉼표)
  isComma  Boolean @default(false) @map("is_comma")
  category String?
  content  String
  hintText String? @map("hint_text")
  isSmile  Boolean @default(false) @map("is_smile")

  letters Letter[]

  @@map("questions")
}

model Letter {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  petId      String   @map("pet_id") @db.Uuid
  questionId String?  @map("question_id") @db.Uuid
  emotionTag String?  @map("emotion_tag")
  content    String
  keywords   String[] @default([])
  imageUrls  String[] @map("image_urls")
  stage      Int
  week       Int
  day        Int
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User      @relation(fields: [userId], references: [id])
  pet      Pet       @relation(fields: [petId], references: [id])
  question Question? @relation(fields: [questionId], references: [id])
  reply    Reply?

  @@map("letters")
}

model Reply {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  letterId    String    @unique @map("letter_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  petId       String    @map("pet_id") @db.Uuid
  content     String
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at") @db.Timestamptz
  generatedAt DateTime  @default(now()) @map("generated_at") @db.Timestamptz

  letter   Letter        @relation(fields: [letterId], references: [id])
  feedback ReplyFeedback?

  @@map("replies")
}

model ReplyFeedback {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  replyId      String   @unique @map("reply_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  petId        String   @map("pet_id") @db.Uuid
  rating       String   // positive | negative
  week         Int
  stage        Int
  letterType   String   @map("letter_type")   // normal | comma_auto | long
  farewellType String?  @map("farewell_type")
  emotionTag   String?  @map("emotion_tag")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  reply Reply @relation(fields: [replyId], references: [id])

  @@map("reply_feedbacks")
}

model EmotionLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  petId      String   @map("pet_id") @db.Uuid
  emotionTag String   @map("emotion_tag")
  letterId   String?  @map("letter_id") @db.Uuid
  loggedAt   DateTime @default(now()) @map("logged_at") @db.Date

  pet Pet @relation(fields: [petId], references: [id])

  @@map("emotion_logs")
}

model JourneyProgress {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  petId              String   @unique @map("pet_id") @db.Uuid
  currentStage       Int      @default(1) @map("current_stage")
  currentWeek        Int      @default(1) @map("current_week")
  currentDay         Int      @default(1) @map("current_day")
  nextStageAvailable Boolean  @default(false) @map("next_stage_available")
  totalLetters       Int      @default(0) @map("total_letters")
  totalMinutes       Int      @default(0) @map("total_minutes")
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  pet Pet @relation(fields: [petId], references: [id])

  @@map("journey_progress")
}

model PhotoCard {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  petId     String   @map("pet_id") @db.Uuid
  stage     Int
  imageUrl  String   @map("image_url")
  quote     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  pet Pet @relation(fields: [petId], references: [id])

  @@map("photo_cards")
}

model GardenSticker {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fromUserId  String   @map("from_user_id") @db.Uuid
  toPetId     String   @map("to_pet_id") @db.Uuid
  stickerType String   @map("sticker_type") // candle | flower | heart
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  fromUser User @relation(fields: [fromUserId], references: [id])
  toPet    Pet  @relation(fields: [toPetId], references: [id])

  @@unique([fromUserId, toPetId, stickerType])
  @@map("garden_stickers")
}

model GardenMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String
  isHidden  Boolean  @default(false) @map("is_hidden")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("garden_messages")
}

model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("push_subscriptions")
}

model Payment {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  orderId String   @unique @map("order_id")
  amount  Int
  plan    String   // pro
  status  String   // success | fail
  paidAt  DateTime @default(now()) @map("paid_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@map("payments")
}
